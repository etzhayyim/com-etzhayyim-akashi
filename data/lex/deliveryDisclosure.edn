{"lexicon" 1, "id" "com.etzhayyim.akashi.deliveryDisclosure", "description" "Delivery disclosure for a public ad artifact: dates, regions, ranges, and source-limited targeting summaries.", "defs" {"main" {"type" "record", "key" "tid", "record" {"type" "object", "required" ["createdAt" "sourceSnapshotCid" "creativeDisclosureCid" "sourceLimited" "attestingDid"], "properties" {"targetingSummaryCid" {"type" "string"}, "creativeDisclosureCid" {"type" "string"}, "createdAt" {"type" "string", "format" "datetime"}, "regionSummary" {"type" "array", "items" {"type" "string"}}, "startedAt" {"type" "string", "format" "datetime"}, "sourceLimited" {"type" "boolean", "const" true}, "spendRange" {"type" "ref", "ref" "#range"}, "status" {"type" "string", "knownValues" ["active" "inactive" "unknown"]}, "sourceSnapshotCid" {"type" "string"}, "endedAt" {"type" "string", "format" "datetime"}, "impressionRange" {"type" "ref", "ref" "#range"}, "attestingDid" {"type" "string", "format" "did"}}}}, "range" {"type" "object", "properties" {"min" {"type" "integer", "minimum" 0}, "max" {"type" "integer", "minimum" 0}, "currency" {"type" "string", "maxLength" 8}, "sourceLabel" {"type" "string", "maxLength" 128}}}}}