{
  "lexicon" : 1,
  "id" : "com.etzhayyim.akashi.advertiserIdentity",
  "description" : "Advertiser/page/account identity exactly as disclosed by a public ad-library source. No private identity inference.",
  "defs" : {
    "main" : {
      "type" : "record",
      "key" : "tid",
      "record" : {
        "type" : "object",
        "required" : [ "createdAt", "platform", "sourceSnapshotCid", "displayName", "nonInferred", "attestingDid" ],
        "properties" : {
          "createdAt" : {
            "type" : "string",
            "format" : "datetime"
          },
          "displayName" : {
            "type" : "string",
            "maxLength" : 512
          },
          "verifiedStatus" : {
            "type" : "string",
            "knownValues" : [ "source-verified", "source-unverified", "not-disclosed" ]
          },
          "pageUrl" : {
            "type" : "string",
            "format" : "uri"
          },
          "platformAdvertiserId" : {
            "type" : "string",
            "maxLength" : 256
          },
          "sourceSnapshotCid" : {
            "type" : "string"
          },
          "jurisdiction" : {
            "type" : "string",
            "maxLength" : 16
          },
          "nonInferred" : {
            "type" : "boolean",
            "const" : true
          },
          "websiteDomain" : {
            "type" : "string",
            "maxLength" : 253
          },
          "platform" : {
            "type" : "string",
            "maxLength" : 64
          },
          "attestingDid" : {
            "type" : "string",
            "format" : "did"
          }
        }
      }
    }
  }
}
