{
  "lexicon": 1,
  "id": "com.etzhayyim.akashi.methodNote",
  "description": "Open, versioned method note for akashi source adapters, parsers, normalizers, landing fetchers, linkers, and malak-candidate criteria.",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["createdAt", "methodId", "methodFamily", "version", "sourceCodeCid", "limits", "attestingDid"],
        "properties": {
          "createdAt": {"type": "string", "format": "datetime"},
          "methodId": {"type": "string", "maxLength": 128},
          "methodFamily": {
            "type": "string",
            "knownValues": ["source-policy", "snapshot-parser", "creative-normalizer", "landing-evidence", "cross-platform-link", "malak-candidate"]
          },
          "version": {"type": "string", "maxLength": 64},
          "sourceCodeCid": {"type": "string"},
          "limits": {"type": "array", "items": {"type": "string"}, "minLength": 1},
          "falsePositiveNotes": {"type": "array", "items": {"type": "string"}},
          "attestingDid": {"type": "string", "format": "did"}
        }
      }
    }
  }
}
