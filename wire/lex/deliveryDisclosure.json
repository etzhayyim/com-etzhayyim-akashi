{
  "lexicon": 1,
  "id": "com.etzhayyim.akashi.deliveryDisclosure",
  "description": "Delivery disclosure for a public ad artifact: dates, regions, ranges, and source-limited targeting summaries.",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["createdAt", "sourceSnapshotCid", "creativeDisclosureCid", "sourceLimited", "attestingDid"],
        "properties": {
          "createdAt": {"type": "string", "format": "datetime"},
          "sourceSnapshotCid": {"type": "string"},
          "creativeDisclosureCid": {"type": "string"},
          "startedAt": {"type": "string", "format": "datetime"},
          "endedAt": {"type": "string", "format": "datetime"},
          "status": {"type": "string", "knownValues": ["active", "inactive", "unknown"]},
          "spendRange": {"type": "ref", "ref": "#range"},
          "impressionRange": {"type": "ref", "ref": "#range"},
          "regionSummary": {"type": "array", "items": {"type": "string"}},
          "targetingSummaryCid": {"type": "string"},
          "sourceLimited": {"type": "boolean", "const": true},
          "attestingDid": {"type": "string", "format": "did"}
        }
      }
    },
    "range": {
      "type": "object",
      "properties": {
        "min": {"type": "integer", "minimum": 0},
        "max": {"type": "integer", "minimum": 0},
        "currency": {"type": "string", "maxLength": 8},
        "sourceLabel": {"type": "string", "maxLength": 128}
      }
    }
  }
}
