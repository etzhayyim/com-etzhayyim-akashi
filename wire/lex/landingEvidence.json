{
  "lexicon": 1,
  "id": "com.etzhayyim.akashi.landingEvidence",
  "description": "Landing-page evidence for a disclosed ad URL. Fetch-only; no form submission, login, purchase, or anti-bot bypass.",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["fetchedAt", "sourceSnapshotCid", "url", "domain", "methodNoteCid", "fetchMode", "attestingDid"],
        "properties": {
          "fetchedAt": {"type": "string", "format": "datetime"},
          "sourceSnapshotCid": {"type": "string"},
          "url": {"type": "string", "format": "uri"},
          "domain": {"type": "string", "maxLength": 253},
          "redirectSummaryCid": {"type": "string"},
          "contentSha256": {"type": "string", "maxLength": 64},
          "httpStatus": {"type": "integer", "minimum": 100, "maximum": 599},
          "safetyFlags": {"type": "array", "items": {"type": "string"}},
          "fetchMode": {"type": "string", "knownValues": ["head-only", "get-static", "manual-review-only"]},
          "methodNoteCid": {"type": "string"},
          "attestingDid": {"type": "string", "format": "did"}
        }
      }
    }
  }
}
