{
  "@context": [
    "https://www.w3.org/ns/activitystreams",
    "https://etzhayyim.com/ns/actor-manifest"
  ],
  "@type": "ActorManifest",
  "id": "did:web:akashi.etzhayyim.com",
  "name": "akashi",
  "displayName": "証 — Public Ad Disclosure Transparency",
  "displayNameJa": "証",
  "displayNameEn": "Akashi",
  "description": "kotoba-native public ad-disclosure transparency actor. Passively ingests already-public platform ad-library disclosures into kotoba EAVT and emits source-cited, non-adjudicating transparency links and aggregate reports. Sibling to danjo; bounded away from malak except for reviewed fraud/malware-ad evidence candidates.",
  "descriptionJa": "公開済みプラットフォーム広告ライブラリ/広告情報開示を受動的に kotoba EAVT へ取り込み、出典付き・非裁定の透明性リンクと集計レポートを出す actor。danjo の広告開示 sibling。malak とは詐欺/マルウェア広告の証拠候補をレビュー付きで渡す境界のみ。",
  "adr": {
    "master": "etzhayyim:adr:2606022300",
    "r0": "etzhayyim:adr:2606022300",
    "r1": "reserved",
    "r2": "reserved",
    "r3": "reserved"
  },
  "tier": "Tier-B",
  "parentActor": null,
  "crossActorBoundary": [
    "did:web:danjo.etzhayyim.com (sibling public-record transparency actor; shared passive/non-adjudicating/open-method pattern)",
    "did:web:malak.etzhayyim.com (optional reviewed malakEvidenceCandidate handoff only; akashi does not create CTI cases or accusations)",
    "did:web:himotoki.etzhayyim.com (personal-data disclosure requests; akashi does not request private data)",
    "did:web:moushibumi.etzhayyim.com (political-neutral citizen participation; akashi does not campaign or profile voters)",
    "kotoba QuadStore EAVT (canonical graph store; no RisingWave / no projection layer)"
  ],
  "lexiconReadAccess": {
    "public.platform.adLibrary.*": "Already-public ad disclosure pages, public APIs or public bulk exports only. Adapter-specific sourcePolicySnapshot required before collection.",
    "public.regulator.adRepository.*": "Official public ad repository exports where available; preferred over scraping.",
    "malak.publicIocFeed": "Read-only public IOC / phishing / malware indicators for candidate evidence linkage; no confidential malak data read at R0.",
    "20-actors/akashi/registry/source-catalog.seed.json": "Planning seed only; does not authorize collection. Each source requires sourcePolicySnapshot + methodNote before use."
  },
  "form": "任意団体 internal public-transparency substrate (NOT an ad network, NOT a regulator, NOT law-enforcement, NOT a commercial ad-intelligence service)",
  "constitutionalDiscipline": {
    "passiveOnly": "G1 — only public disclosure pages, official APIs, or public bulk exports; no logged-in scraping, sockpuppets, credentialed access, or anti-bot bypass.",
    "sourceProvenanceMandatory": "G2 — every datom points to source URL/API, fetched_at, payload hash/CID, source record ID where available, and parser/method version.",
    "nonAdjudicating": "G3 — no claim that an ad is illegal, fraudulent, manipulative, or electioneering beyond source-disclosed categories.",
    "noPoliticalProfiling": "G4 — no voter/person cohorts, persuasion scores, supporter/opponent graphs, or per-person political-interest records.",
    "noTargetLists": "G5 — aggregate-first reporting; named advertiser views only mirror source-public names and are gated for sensitive categories.",
    "openMethod": "G6 — all parsers, normalizers and linkers publish methodNote.",
    "sourcePolicyRequired": "G7 — adapter cannot run unless sourcePolicySnapshot allows intended access mode.",
    "noAdSdk": "G8 — no Meta Pixel, GA4 ads integration, third-party ad SDK, affiliate/tracking code.",
    "noCommercialAdIntel": "G9 — no paid targeting terminal, advertiser lead-gen resale, or competitor-intel SaaS.",
    "publicRecordMinimization": "G10 — keep source-disclosed facts and content hashes; do not infer private natural-person data.",
    "murakumoOnlyInference": "G11 — Murakumo-only inference; no vendor LLM APIs.",
    "transparentForce": "G12 — observation and transparent publication only; no coercive action or covert operation.",
    "malakBridgeReview": "G13 — malakEvidenceCandidate is evidence only, never an accusation; malak import requires malak gates."
  },
  "cells": [
    {
      "name": "source_registry",
      "module": "kotodama.cells.akashi_source_registry",
      "murakumoNode": "reuben",
      "phase": "periodic",
      "io": "curated public source registry -> sourcePolicySnapshot"
    },
    {
      "name": "disclosure_fetch",
      "module": "kotodama.cells.akashi_disclosure_fetch",
      "murakumoNode": "reuben",
      "phase": "periodic",
      "io": "public source/API/bulk export -> raw payload CID + adDisclosureSnapshot"
    },
    {
      "name": "normalize_creative",
      "module": "kotodama.cells.akashi_normalize_creative",
      "murakumoNode": "reuben",
      "phase": "continuous",
      "io": "snapshot payload -> advertiser / creative / delivery datoms"
    },
    {
      "name": "landing_evidence",
      "module": "kotodama.cells.akashi_landing_evidence",
      "murakumoNode": "gad",
      "phase": "rate-limited",
      "io": "disclosed landing URL -> redirect/domain/hash evidence"
    },
    {
      "name": "cross_platform_link",
      "module": "kotodama.cells.akashi_cross_platform_link",
      "murakumoNode": "gad",
      "phase": "continuous",
      "io": "advertiser/domain/creative hashes -> non-adjudicating adDisclosureLink"
    },
    {
      "name": "transparency_report",
      "module": "kotodama.cells.akashi_transparency_report",
      "murakumoNode": "naphtali",
      "phase": "periodic",
      "io": "aggregate trends -> adTransparencyReport"
    },
    {
      "name": "malak_evidence_bridge",
      "module": "kotodama.cells.akashi_malak_evidence_bridge",
      "murakumoNode": "gad",
      "phase": "event-gated",
      "io": "explicit fraud/malware flags -> optional malakEvidenceCandidate"
    }
  ],
  "lexiconNamespaces": [
    "com.etzhayyim.akashi.sourcePolicySnapshot",
    "com.etzhayyim.akashi.adDisclosureSnapshot",
    "com.etzhayyim.akashi.advertiserIdentity",
