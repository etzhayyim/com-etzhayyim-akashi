{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "com.etzhayyim.akashi.sourcePolicyApprovalTx",
  "title": "akashi source policy approval transaction",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "txId",
    "createdAt",
    "adr",
    "sourceId",
    "decision",
    "runtime",
    "approvedAccessModes",
    "evidence",
    "reviewerDid",
    "attestingDid",
    "rollback"
  ],
  "properties": {
    "txId": {
      "type": "string",
      "pattern": "^akashi-source-policy-[a-z0-9-]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "adr": {
      "type": "string",
      "const": "etzhayyim:adr:2606022300"
    },
    "sourceId": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": ["disabled", "manual-review", "fixture-only", "allowed"]
    },
    "runtime": {
      "type": "string",
      "enum": ["disabled", "fixture-only", "live-adapter"]
    },
    "approvedAccessModes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "public-page",
          "public-bulk-export",
          "manual-review-only",
          "disabled"
        ]
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "termsReviewCid",
        "publicAccessProofCid",
        "fixtureParserCid",
        "methodNoteCid",
        "rateLimitReviewCid"
      ],
      "properties": {
        "termsReviewCid": {
          "type": "string"
        },
        "robotsOrApiPolicyCid": {
          "type": "string"
        },
        "publicAccessProofCid": {
          "type": "string"
        },
        "fixtureParserCid": {
          "type": "string"
        },
        "methodNoteCid": {
          "type": "string"
        },
        "rateLimitReviewCid": {
          "type": "string"
        },
        "licenseReviewCid": {
          "type": "string"
        }
      }
    },
    "reviewerDid": {
      "type": "string"
    },
    "attestingDid": {
      "type": "string",
      "const": "did:web:akashi.etzhayyim.com"
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["disableTxRequired", "defaultRuntimeAfterRollback"],
      "properties": {
        "disableTxRequired": {
          "type": "boolean",
          "const": true
        },
        "defaultRuntimeAfterRollback": {
          "type": "string",
          "const": "disabled"
        }
      }
    }
  }
}
